# ========================================
# Labfinity Frontend Environment Configuration
# ========================================
#
# Copy this file to `.env` (root directory, next to package.json)
# and fill in your values.
# NEVER commit secrets to git.

# ========== API URL ==========
# Backend API server address (dev).
# Change to your production URL when deploying.
VITE_API_URL=http://localhost:8000

# ========== GOOGLE OAUTH ==========
# Google OAuth 2.0 Client ID for the web app.
# Get it from: https://console.cloud.google.com/
# This value is safe to expose in the frontend (it's client-side only).
VITE_GOOGLE_CLIENT_ID=1234567890-abcdefg.apps.googleusercontent.com
