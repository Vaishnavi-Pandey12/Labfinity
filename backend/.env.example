# ========================================
# Labfinity Backend Environment Configuration
# ========================================
#
# Copy this file to `.env` and fill in your actual values.
# NEVER commit the `.env` file itself to git — it contains secrets.

# ========== DATABASE ==========
# PostgreSQL connection string for Neon.
# Format: postgresql://user:password@host:port/dbname
# Make sure sslmode=require is included for secure Neon connections.
DATABASE_URL=postgresql://user:password@host.neon.tech:5432/dbname?sslmode=require

# ========== JWT SECRETS ==========
# Random string used to sign JWT access tokens.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# KEEP THIS SECRET AND DON'T SHARE IT.
SECRET_KEY=your_random_secret_key_here_at_least_32_chars

# ========== GOOGLE OAUTH ==========
# OAuth 2.0 Client ID from Google Cloud Console.
# Get it from: https://console.cloud.google.com/
# - Create OAuth 2.0 Client ID (Web application)
# - Add authorized redirect URIs and JavaScript origins
# - Copy the "Client ID" value and paste here
GOOGLE_CLIENT_ID=1234567890-abcdefg.apps.googleusercontent.com
